{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RetroHydra",
  "version": "0.1.0",
  "identifier": "app.retrohydra.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "RetroHydra",
        "width": 1360,
        "height": 840,
        "minWidth": 960,
        "minHeight": 680,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: http://localhost http://127.0.0.1 data:; media-src 'self' https: http://localhost http://127.0.0.1; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
